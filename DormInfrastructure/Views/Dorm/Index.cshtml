@model IEnumerable<Dorm>
@{
    ViewData["Title"] = "Гуртожитки";
}

<h2>Гуртожитки</h2>
<p><a asp-action="Create" class="btn btn-primary">+ Додати</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Номер</th>
            <th>Адреса</th>
            <th>Поверхів</th>
            <th>Комендант</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.GuNomer</td>
                <td>@item.GuAdresa</td>
                <td>@item.GuKilkistPoverh</td>
                <td>@item.GuKomendant</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>