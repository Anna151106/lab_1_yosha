@model IEnumerable<Room>
@{
    ViewData["Title"] = "Кімнати";
}

<h2>Кімнати</h2>
<p><a asp-action="Create" class="btn btn-primary">+ Додати</a></p>

<table class="table table-striped">
    <thead>
        <tr><th>Номер</th><th>Гуртожиток</th><th>Поверх</th><th>Місткість</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.KiNomer</td>
                <td>@item.Gu?.GuNomer</td>
                <td>@item.KiPoverh</td>
                <td>@item.KiMistkist</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>