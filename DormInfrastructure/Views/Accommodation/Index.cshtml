@model IEnumerable<Accommodation>
@{
    ViewData["Title"] = "Проживання";
}

<h2>Проживання</h2>
<p><a asp-action="Create" class="btn btn-primary">+ Додати</a></p>

<table class="table table-striped">
    <thead>
        <tr><th>Студент</th><th>Кімната</th><th>Гуртожиток</th><th>Дата заселення</th><th>Дата виселення</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.St?.StPib</td>
                <td>@item.Ki?.KiNomer</td>
                <td>@item.Ki?.Gu?.GuNomer</td>
                <td>@item.PrDataZasel.ToString("dd.MM.yyyy")</td>
                <td>@(item.PrDataVysel?.ToString("dd.MM.yyyy") ?? "—")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>