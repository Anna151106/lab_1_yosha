@model Faculty
@{
    ViewData["Title"] = "Додати факультет";
}

<h2>Додати факультет</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="FaName" class="form-label">Назва</label>
                <input asp-for="FaName" class="form-control" />
                <span asp-validation-for="FaName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FaDekan" class="form-label">Декан</label>
                <input asp-for="FaDekan" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="FaKorpus" class="form-label">Корпус</label>
                <input asp-for="FaKorpus" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="FaTelefon" class="form-label">Телефон</label>
                <input asp-for="FaTelefon" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="FaInformation" class="form-label">Інформація</label>
                <textarea asp-for="FaInformation" class="form-control"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Зберегти</button>
            <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}