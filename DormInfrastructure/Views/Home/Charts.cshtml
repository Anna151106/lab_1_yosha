@{
    ViewData["Title"] = "Аналітика";

    var facultyLabels = System.Text.Json.JsonSerializer.Serialize(ViewBag.FacultyLabels ?? new List<string>());
    var facultyData = System.Text.Json.JsonSerializer.Serialize(ViewBag.FacultyData ?? new List<int>());
    var dormLabels = System.Text.Json.JsonSerializer.Serialize(ViewBag.DormLabels ?? new List<string>());
    var roomData = System.Text.Json.JsonSerializer.Serialize(ViewBag.RoomData ?? new List<int>());
    var accData = System.Text.Json.JsonSerializer.Serialize(ViewBag.AccommodationData ?? new List<int>());
}

<h2>Аналітика гуртожитку</h2>

<div class="row mt-4">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Студентів по факультетах</div>
            <div class="card-body">
                <canvas id="facultyChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Кімнати та мешканці по гуртожитках</div>
            <div class="card-body">
                <canvas id="dormChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">📁 Робота з файлами</div>
            <div class="card-body d-flex gap-3 flex-wrap">
                <a asp-action="ExportFacultyToExcel" asp-controller="Home" class="btn btn-success">
                    ⬇ Експорт: студенти по факультетах
                </a>
                <a asp-action="ExportDormsToExcel" asp-controller="Home" class="btn btn-success">
                    ⬇ Експорт: звіт по гуртожитках
                </a>
                <a asp-action="Import" asp-controller="Home" class="btn btn-outline-primary">
                    ⬆ Імпорт студентів з Excel
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('facultyChart'), {
        type: 'bar',
        data: {
        labels: @Html.Raw(facultyLabels),
        datasets: [{
        label: 'Кількість студентів',
        data: @Html.Raw(facultyData),
        backgroundColor: 'rgba(15, 52, 96, 0.75)',
        borderColor: '#0f3460',
        borderWidth: 1,
        borderRadius: 6
        }]
        },
        options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
        });

        new Chart(document.getElementById('dormChart'), {
        type: 'bar',
        data: {
        labels: @Html.Raw(dormLabels),
        datasets: [
        {
        label: 'Кімнат всього',
        data: @Html.Raw(roomData),
        backgroundColor: 'rgba(15, 52, 96, 0.75)',
        borderRadius: 6
        },
        {
        label: 'Зараз мешкає',
        data: @Html.Raw(accData),
        backgroundColor: 'rgba(233, 69, 96, 0.75)',
        borderRadius: 6
        }
        ]
        },
        options: {
        responsive: true,
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
        });
    </script>
}