@model Department
@{
    ViewData["Title"] = "Додати кафедру";
}

<h2>Додати кафедру</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="FaId" class="form-label">Факультет</label>
                <select asp-for="FaId" class="form-select" asp-items="ViewBag.FaId">
                    <option value="">-- Оберіть факультет --</option>
                </select>
                <span asp-validation-for="FaId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="KaName" class="form-label">Назва</label>
                <input asp-for="KaName" class="form-control" />
                <span asp-validation-for="KaName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="KaZaviduvach" class="form-label">Завідувач</label>
                <input asp-for="KaZaviduvach" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="KaTelefon" class="form-label">Телефон</label>
                <input asp-for="KaTelefon" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="KaInformation" class="form-label">Інформація</label>
                <textarea asp-for="KaInformation" class="form-control"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Зберегти</button>
            <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}