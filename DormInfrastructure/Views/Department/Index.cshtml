@model IEnumerable<Department>
@{
    ViewData["Title"] = "Кафедри";
}

<h2>Кафедри</h2>
<p><a asp-action="Create" class="btn btn-primary">+ Додати</a></p>

<table class="table table-striped">
    <thead>
        <tr><th>Назва</th><th>Факультет</th><th>Завідувач</th><th>Телефон</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.KaName</td>
                <td>@item.Fa?.FaName</td>
                <td>@item.KaZaviduvach</td>
                <td>@item.KaTelefon</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>